# Copy this file to .env.local for local development
# For Vercel: set this in Project → Settings → Environment Variables

# Development (local): leave empty or set to http://localhost:8000
VITE_API_BASE_URL=

# Production (Vercel): set to your Hugging Face Space URL, e.g.:
# VITE_API_BASE_URL=https://your-username-bioscope-backend.hf.space
